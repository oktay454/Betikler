#!/bin/bash
# shellcheck source=/dev/null
set -e
umask 0022

##########################################################################################
# Temel Değişkenler
##########################################################################################
# shellcheck disable=SC2034
DEBIAN_FRONTEND="noninteractive"
LXC_DIR="/var/lib/lxc"
PRODUCT_NAME="template-deb13"
LXC_IP="10.0.3.200"

PUBLISH_CERT="/usr/local/sbin/publish-cert"
SET_LXC_NETWORK_RULES="/usr/local/sbin/set-lxc-network-rules"
NETWORK_RULES="/etc/lxc/network-rules.conf"

##########################################################################################
# Sistemin dili yapılandırıyor
##########################################################################################
cat > "/etc/default/locale" << DEFAULT_LOCALE
LANGUAGE=en_US.UTF-8
LC_ALL=en_US.UTF-8
LC_CTYPE=en_US.UTF-8
LANG=en_US.UTF-8
DEFAULT_LOCALE

cat > "/etc/locale.gen" << LOCALE
en_US.UTF-8 UTF-8
tr_TR.UTF-8 UTF-8
LOCALE
locale-gen
update-locale "LANG=en_US.UTF-8"

##########################################################################################
# Depoları yeniden oluşturma, temel sistem araçları ve gerekli paketlerin kurulumu
##########################################################################################
cat > "/etc/apt/sources.list" << \SOURCES_LIST
deb http://deb.debian.org/debian/ trixie main contrib non-free non-free-firmware
deb http://deb.debian.org/debian-security trixie-security main contrib non-free non-free-firmware
deb http://deb.debian.org/debian/ trixie-updates main contrib non-free non-free-firmware
SOURCES_LIST
apt purge -y --auto-remove apt-listchanges ufw iptables
apt update
apt install -y \
	bash-completion openssh-server fzf autojump \
	file tree htop vim tmux wget curl coreutils locales \
	moreutils apt-transport-https gnupg certbot \
	debconf-utils bind9-dnsutils lxc lxc-templates nftables gawk \
	unattended-upgrades needrestart netcat-openbsd

cat > "/etc/apt/apt.conf.d/20keepconfig.conf" <<\APT_KEEP_CONFIG
Dpkg::Options {
	"--force-confdef";
	"--force-confold";
}
APT_KEEP_CONFIG

##########################################################################################
# NeedRestart için otomatik yeniden başlatma
##########################################################################################
cat > "/etc/needrestart/conf.d/90-automatic-restart.conf" <<\NEEDRESTART_CONFIG
$nrconf{restart} = 'a';
NEEDRESTART_CONFIG

##########################################################################################
# Kullanıma dair düzenlemeler
##########################################################################################
cat > "/etc/vim/vimrc.local" << \VIM_CONFIG
source $VIMRUNTIME/defaults.vim
let skip_defaults_vim = 1
set noswapfile
set ignorecase
set smartcase
if has("mouse")
  set mouse=r
endif
VIM_CONFIG

chsh -s /bin/bash root

cat > "/root/.bashrc" << \BASHRC
# Color Bash Prompt
export PS1="\[\033[38;5;11m\]\u\[\033[38;5;9m\]@\h:\[\033[38;5;118m\][\$?]\[\033[38;5;51m\][\w]\[\033[38;5;6m\][\d - \t]\n\[\033[38;5;10m\][\\$\[\033[38;5;10m\]]\[\033[38;5;202m\]>\[\033[38;5;15m\]"

# Alias definitions.
# You may want to put all your additions into a separate file like
# ~/.bash_aliases, instead of adding them here directly.
# See /usr/share/doc/bash-doc/examples in the bash-doc package.

if [ -f ~/.bash_aliases ]; then
    . ~/.bash_aliases
fi

if [ -f ~/.bash_functions ]; then
    . ~/.bash_functions
fi

# If FZF is installed
if [ -f /usr/share/doc/fzf/examples/key-bindings.bash ]; then
    . /usr/share/doc/fzf/examples/key-bindings.bash
fi

# colored GCC warnings and errors
export GCC_COLORS='error=01;31:warning=01;35:note=01;36:caret=01;32:locus=01:quote=01'

# For Bash completion to work
if ! shopt -oq posix; then
  if [ -f /usr/share/bash-completion/bash_completion ]; then
    . /usr/share/bash-completion/bash_completion
  elif [ -f /etc/bash_completion ]; then
    . /etc/bash_completion
  fi
fi

# append to the history file, don't overwrite it
shopt -s histappend

# don't put duplicate lines or lines starting with space in the history.
# See bash(1) for more options
HISTCONTROL=ignoreboth

# for setting history length see HISTSIZE and HISTFILESIZE in bash(1)
export HISTSIZE=-1
export HISTFILESIZE=-1

export PROMPT_COMMAND="history -a;$PROMPT_COMMAND"
export LS_OPTIONS='--color=auto'
eval "`dircolors`"

# Aliases
alias ls='ls $LS_OPTIONS'
alias ll='ls $LS_OPTIONS -lh'
alias l='ls $LS_OPTIONS -lAh'
alias c='clear'
alias r='reset'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'
alias ......='cd ../../../../..'
BASHRC

# MOTD özellikleri
cat > "/etc/update-motd.d/20-lxc-list" << \MOTD_LXC_LIST
#!/bin/bash
if command -v lxc-ls > /dev/null 2>&1
then
	echo "#######################################################################"
	lxc-ls -f
	echo "#######################################################################"
	echo
fi
MOTD_LXC_LIST
chmod +x "/etc/update-motd.d/20-lxc-list"

cat > "/etc/update-motd.d/30-tmux-list" << \MOTD_TMUX_LIST
#!/bin/bash
if command -v tmux > /dev/null 2>&1
then
	echo "#######################################################################"
	tmux ls 2>/dev/null || echo "There is no TMUX session open."
	echo "#######################################################################"
	echo
fi
MOTD_TMUX_LIST
chmod +x "/etc/update-motd.d/30-tmux-list"

chattr -i "/etc/motd"
rm "/etc/motd"
touch "/etc/motd"
chattr +i "/etc/motd"

##########################################################################################
# SSH yapılandırması
##########################################################################################
install -dm0700 ~/.ssh
wget "https://oktayaktogan.com.tr/ssh-keys.pub" -O ~/.ssh/authorized_keys
cat > "/etc/ssh/sshd_config.d/99-common.conf" << SSH_CONFIG
PermitRootLogin prohibit-password
PubkeyAuthentication yes
PasswordAuthentication no
PermitEmptyPasswords no
PrintMotd yes
PrintLastLog no
SSH_CONFIG
systemctl restart ssh.service

##########################################################################################
# JournalD yapılandırması
##########################################################################################
mkdir -p "/etc/systemd/journald.conf.d"
cat >> "/etc/systemd/journald.conf.d/99-delete-after-one-week.conf" <<JOURNALD
MaxRetentionSec=1week
MaxFileSec=1week
JOURNALD

##########################################################################################
# Certbot için ek araçlar
##########################################################################################
# Certbot'un çalışması akabinde sertifika ve anahtarlarını dizine kopyamalak için betik
cat > "${PUBLISH_CERT}" << \PUBLISH_CERT
#!/bin/bash

LE_LIVE_DIR="/etc/letsencrypt/live"
CERTS_DIR="/usr/local/share/certificates"
DIRS="$(find ${LE_LIVE_DIR} -mindepth 1 -maxdepth 1 -type d)"
FQDNS="$(awk -F "/" '{ print $NF }' <<< "${DIRS}")"

for FQDN in ${FQDNS}
do
	FULLCHAIN="$(realpath "${LE_LIVE_DIR}/${FQDN}/fullchain.pem")"
	PRIVKEY="$(realpath "${LE_LIVE_DIR}/${FQDN}/privkey.pem")"
	if ! [ -f "${FULLCHAIN}" ] || ! [ -f "${PRIVKEY}" ]
	then
		continue
	fi
	install -Dm0444 "${FULLCHAIN}" "${CERTS_DIR}/${FQDN}/fullchain.pem"
	install -Dm0444 "${PRIVKEY}" "${CERTS_DIR}/${FQDN}/privkey.pem"
done
PUBLISH_CERT
chmod +x "${PUBLISH_CERT}"
install -d "/etc/letsencrypt/renewal-hooks/post/"
ln -sf "${PUBLISH_CERT}" "/etc/letsencrypt/renewal-hooks/post/publish-cert"

# Certbot hizmetine tetikleyici ekleme
mkdir -p "/etc/systemd/system/certbot.service.d"
cat > "/etc/systemd/system/certbot.service.d/50-pusbish-cert.conf" << SERVICE
[Service]
ExecStartPost=${PUBLISH_CERT}
SERVICE
systemctl daemon-reload

##########################################################################################
# LXC ağ ortamının yapılandırılması
##########################################################################################
cat > "/etc/default/lxc-net" << \LXC_NET
USE_LXC_BRIDGE="true"
LXC_BRIDGE="lxcbr0"
LXC_BRIDGE_MAC="00:16:3e:00:00:00"
LXC_ADDR="10.0.3.1"
LXC_NETMASK="255.255.255.0"
LXC_NETWORK="10.0.3.0/24"
LXC_DHCP_RANGE="10.0.3.200,10.0.3.254"
LXC_DHCP_MAX="253"
LXC_DHCP_CONFILE=""
LXC_DHCP_PING="true"
LXC_DOMAIN=""
LXC_USE_NFT="true"

LXC_IPV6_ENABLE="false"
LXC_IPV6_ADDR="fc42:5009:ba4b:5ab0::1"
LXC_IPV6_MASK="64"
LXC_IPV6_NETWORK="fc42:5009:ba4b:5ab0::/64"
LXC_IPV6_NAT="true"

LXC_DHCP_CONFILE="/etc/lxc/dnsmasq.conf"
LXC_NET

if [ ! -f "/etc/lxc/dnsmasq.conf" ]
then
	rm -rf "/etc/lxc/dnsmasq.conf"
	cat > "/etc/lxc/dnsmasq.conf" << \DNSMASQ
no-negcache
cache-size=0

# Örnek DNS kaydı
#address=/example.com/10.0.3.200
DNSMASQ
if

cat > "/etc/sysctl.d/40-network-optimization.conf" << \NETWORK_OPTIMIZATION
# TCP ve UDP tampon bellek
net.core.rmem_max = 16777216
net.core.wmem_max = 16777216
net.ipv4.tcp_rmem= 10240 87380 16777216
net.ipv4.tcp_wmem= 10240 87380 16777216
net.ipv4.tcp_window_scaling = 1
net.ipv4.tcp_timestamps = 1
net.ipv4.tcp_sack = 1
net.ipv4.tcp_no_metrics_save = 1
net.ipv4.udp_mem = 90651 120871 16777216

# Çekirdeğin işleyebileceği paket sayısı
net.core.netdev_max_backlog=16384

# ARP tablosu taşmasını önleme
net.ipv4.neigh.default.gc_thresh1 = 1024
net.ipv4.neigh.default.gc_thresh2 = 2048
net.ipv4.neigh.default.gc_thresh3 = 4096
NETWORK_OPTIMIZATION
sysctl -p "/etc/sysctl.d/40-network-optimization.conf"

# Ağ kuralları /etc/lxc/network-rules.conf dosyasına eklenir.
# Daha kolay yönetebilirlik sağlamak için böyle bir yöntem tercih edildi.
cat > "${SET_NFT_RULES}" << \SET_LXC_NETWORK_RULES
#!/bin/bash

sleep 2
LXC_NET_DEFAULT_FILE="/etc/default/lxc-net"
NETWORK_RULES="/etc/lxc/network-rules.conf"

if [ -f "${LXC_NET_DEFAULT_FILE}" ] && [ -r "${LXC_NET_DEFAULT_FILE}" ]
then
	source "${LXC_NET_DEFAULT_FILE}" || true
fi

[ -z "${USE_LXC_BRIDGE}" ] && USE_LXC_BRIDGE="true"
[ -z "${LXC_BRIDGE}" ] && LXC_BRIDGE="lxcbr0"
[ -z "${LXC_BRIDGE_MAC}" ] && LXC_BRIDGE_MAC="00:16:3e:00:00:00"
[ -z "${LXC_ADDR}" ] && LXC_ADDR="10.0.3.1"
[ -z "${LXC_NETMASK}" ] && LXC_NETMASK="255.255.255.0"
[ -z "${LXC_NETWORK}" ] && LXC_NETWORK="10.0.3.0/24"
[ -z "${LXC_DHCP_RANGE}" ] && LXC_DHCP_RANGE="10.0.3.200,10.0.3.254"
[ -z "${LXC_DHCP_MAX}" ] && LXC_DHCP_MAX="253"
[ -z "${LXC_DHCP_PING}" ] && LXC_DHCP_PING="true"
[ -z "${LXC_DOMAIN}" ] && LXC_DOMAIN=""
[ -z "${LXC_USE_NFT}" ] && LXC_USE_NFT="true"

[ -z "${LXC_IPV6_ENABLE}" ] && LXC_IPV6_ENABLE="false"
[ -z "${LXC_IPV6_ADDR}" ] && LXC_IPV6_ADDR="fc42:5009:ba4b:5ab0::1"
[ -z "${LXC_IPV6_MASK}" ] && LXC_IPV6_MASK="64"
[ -z "${LXC_IPV6_NETWORK}" ] && LXC_IPV6_NETWORK="fc42:5009:ba4b:5ab0::/64"
[ -z "${LXC_IPV6_NAT}" ] && LXC_IPV6_NAT="true"

[ -z "${LXC_DHCP_CONFILE}" ] && LXC_DHCP_CONFILE="/etc/lxc/dnsmasq.conf"

# LXC ağı kullanılmayacaksa kuralları temizleyip çıkar.
if [ "${USE_LXC_BRIDGE}" != "true" ]
then
	nft delete table inet filter 2>/dev/null || true
	nft delete table ip nat 2>/dev/null || true
	nft delete table ip6 nat 2>/dev/null || true

	iptables -F 2>/dev/null || true
	iptables -X 2>/dev/null || true
	iptables -t nat -F 2>/dev/null || true
	iptables -t nat -X 2>/dev/null || true

	ip6tables -F 2>/dev/null || true
	ip6tables -X 2>/dev/null || true
	ip6tables -t nat -F 2>/dev/null || true
	ip6tables -t nat -X 2>/dev/null || true

	exit 0
fi

# WAN portu ve IP adresi tesbit edilir.
[ -z "${WAN_IF}" ] && WAN_IF="$(awk '$2 == "00000000" { print $1 }' "/proc/net/route")"
[ -z "${WAN_IP}" ] && WAN_IP="$(ip -4 addr show "${WAN_IF}" | grep -oP '(?<=inet\s)\d+(\.\d+){3}' | grep -v ^127 | head -n 1)"
[ -z "${WAN_IP}" ] && WAN_IP6="$(ip -6 addr show "${WAN_IF}" | grep "scope global" | grep -oP '(?<=inet6\s)[a-fA-F0-9:]+' | head -n 1)"


if [ "${LXC_USE_NFT}" == "true" ]
then
	# IPv4 Yönlendirme İşlevi
	function AddPortForward() {
		local PROTO=$1
		local PORT=$2
		local TARGET_IP=$3
		local TARGET_PORT=${4:-$PORT}

		nft add rule ip nat prerouting iif "${WAN_IF}" "${PROTO}" dport "${PORT}" dnat to "${TARGET_IP}:${TARGET_PORT}"
		nft add rule ip nat prerouting iif "${LXC_BRIDGE}" ip daddr "${WAN_IP}" "${PROTO}" dport "${PORT}" dnat to "${TARGET_IP}:${TARGET_PORT}"
		nft add rule ip nat output oif "lo" "${PROTO}" dport "${PORT}" dnat to "${TARGET_IP}:${TARGET_PORT}"
	}

	# IPv6 Yönlendirme İşlevi
	function AddPortForward6() {
		local PROTO=$1
		local PORT=$2
		local TARGET_IP6=$3
		local TARGET_PORT=${4:-$PORT}

		# Dış ağdan (WAN) gelen yönlendirmeler
		nft add rule ip6 nat prerouting iif "${WAN_IF}" "${PROTO}" dport "${PORT}" dnat to "[${TARGET_IP6}]:${TARGET_PORT}"

		# İç ağdan (LXC) dış IP'ye gelen yönlendirmeler (Sadece WAN_IP6 tanımlıysa çalışır)
		if [ -n "${WAN_IP6}" ]; then
			nft add rule ip6 nat prerouting iif "${LXC_BRIDGE}" ip6 daddr "${WAN_IP6}" "${PROTO}" dport "${PORT}" dnat to "[${TARGET_IP6}]:${TARGET_PORT}"
		fi

		# Sunucunun kendisinden (localhost) giden istekler (Hairpin NAT)
		nft add rule ip6 nat output oif "lo" "${PROTO}" dport "${PORT}" dnat to "[${TARGET_IP6}]:${TARGET_PORT}"
	}

	##########################################################################################
	# Genel nftables yapılandırması
	##########################################################################################
	nft delete table inet filter 2>/dev/null || true
	nft delete table ip nat 2>/dev/null || true
	nft delete table ip6 nat 2>/dev/null || true

	# table: filter (Hem IPv4 hem IPv6 için geçerlidir)
	nft add table inet filter
	nft add chain inet filter input { type filter hook input priority 0\; policy drop\; }
	nft add chain inet filter forward { type filter hook forward priority 0\; policy drop\; }
	nft add chain inet filter output { type filter hook output priority 0\; policy accept\; }

	nft add rule inet filter input ct state related,established counter accept
	nft add rule inet filter input meta l4proto icmp icmp type echo-request accept
	nft add rule inet filter input tcp dport 22 counter accept
	nft add rule inet filter input iifname "lo" accept
	nft add rule inet filter input iifname "${LXC_BRIDGE}" accept

	nft add rule inet filter forward ct state established,related accept
	nft add rule inet filter forward iifname "${LXC_BRIDGE}" oifname "${WAN_IF}" accept
	nft add rule inet filter forward ct status dnat accept
	nft add rule inet filter output iif "${WAN_IF}" ip daddr "${LXC_NETWORK}" drop

	# table: nat (Sadece IPv4 için)
	nft add table ip nat
	nft add chain ip nat prerouting { type nat hook prerouting priority 0 \; }
	nft add chain ip nat postrouting { type nat hook postrouting priority 100 \; }
	nft add chain ip nat output { type nat hook output priority 0 \; }
	nft add chain ip nat input { type nat hook input priority 0 \; }
	nft add rule ip nat postrouting ip saddr "${LXC_NETWORK}" masquerade

	# table: nat6 (Sadece IPv6 için)
	if [ "${LXC_IPV6_NAT}" = "true" ]; then
		nft add table ip6 nat
		nft add chain ip6 nat prerouting { type nat hook prerouting priority 0 \; }
		nft add chain ip6 nat postrouting { type nat hook postrouting priority 100 \; }
		nft add chain ip6 nat output { type nat hook output priority 0 \; }
		nft add chain ip6 nat input { type nat hook input priority 0 \; }

		nft add rule ip6 nat postrouting ip6 saddr "${LXC_IPV6_NETWORK}" masquerade
	fi
	##########################################################################################
else
	AddPortForward() {
		local PROTO=$1
		local PORT=$2
		local TARGET_IP=$3
		local TARGET_PORT=${4:-$PORT}

		# Dış ağdan (WAN) ve iç ağdan (LXC) dış IP'ye gelen yönlendirmeler
		iptables -t nat -A PREROUTING -d "${WAN_IP}" -p "${PROTO}" --dport "${PORT}" -j DNAT --to-destination "${TARGET_IP}:${TARGET_PORT}"

		# Sunucunun kendisinden (localhost) dış IP'ye giden istekler (Hairpin NAT)
		iptables -t nat -A OUTPUT -d "${WAN_IP}" -p "${PROTO}" --dport "${PORT}" -j DNAT --to-destination "${TARGET_IP}:${TARGET_PORT}"
	}

	# IPv6 Yönlendirme İşlevi (Function)
	AddPortForward6() {
		local PROTO=$1
		local PORT=$2
		local TARGET_IP6=$3
		local TARGET_PORT=${4:-$PORT}

		# Eğer WAN_IP6 tanımlıysa net IP üzerinden yönlendir
		if [ -n "${WAN_IP6}" ]; then
			ip6tables -t nat -A PREROUTING -d "${WAN_IP6}" -p "${PROTO}" --dport "${PORT}" -j DNAT --to-destination "[${TARGET_IP6}]:${TARGET_PORT}"
			ip6tables -t nat -A OUTPUT -d "${WAN_IP6}" -p "${PROTO}" --dport "${PORT}" -j DNAT --to-destination "[${TARGET_IP6}]:${TARGET_PORT}"
		else
			# WAN_IP6 bilinmiyorsa, WAN_IF arayüzünden gelen tüm trafiği yönlendir
			ip6tables -t nat -A PREROUTING -i "${WAN_IF}" -p "${PROTO}" --dport "${PORT}" -j DNAT --to-destination "[${TARGET_IP6}]:${TARGET_PORT}"
		fi
	}

	##########################################################################################
	# Genel iptables ve ip6tables yapılandırması
	##########################################################################################
	# --------------------------------- IPv4 BÖLÜMÜ ------------------------------------------
	iptables -F
	iptables -X
	iptables -t nat -F
	iptables -t nat -X

	iptables -P INPUT DROP
	iptables -P FORWARD DROP
	iptables -P OUTPUT ACCEPT

	# IPv4 INPUT Zinciri (Chain)
	iptables -A INPUT -m state --state RELATED,ESTABLISHED -j ACCEPT
	iptables -A INPUT -p icmp --icmp-type echo-request -j ACCEPT
	iptables -A INPUT -p tcp --dport 22 -j ACCEPT
	iptables -A INPUT -i lo -j ACCEPT
	iptables -A INPUT -i "${LXC_BRIDGE}" -j ACCEPT

	# IPv4 FORWARD Zinciri (Chain)
	iptables -A FORWARD -m state --state RELATED,ESTABLISHED -j ACCEPT
	iptables -A FORWARD -i "${LXC_BRIDGE}" -o "${WAN_IF}" -j ACCEPT
	iptables -A FORWARD -d "${LXC_NETWORK}" -j ACCEPT
	iptables -A OUTPUT -o "${WAN_IF}" -d "${LXC_NETWORK}" -j DROP

	# IPv4 NAT ve Kaynak IP Dönüşümü (SNAT)
	iptables -t nat -A POSTROUTING -s "${LXC_NETWORK}" ! -o "${LXC_BRIDGE}" -j SNAT --to-source "${WAN_IP}"

	# --------------------------------- IPv6 BÖLÜMÜ ------------------------------------------
	ip6tables -F 2>/dev/null || true
	ip6tables -X 2>/dev/null || true
	ip6tables -t nat -F 2>/dev/null || true
	ip6tables -t nat -X 2>/dev/null || true

	if [ "${LXC_IPV6_ENABLE}" = "true" ]; then
		ip6tables -P INPUT DROP
		ip6tables -P FORWARD DROP
		ip6tables -P OUTPUT ACCEPT

		# IPv6 INPUT Zinciri (Chain)
		ip6tables -A INPUT -m state --state RELATED,ESTABLISHED -j ACCEPT
		ip6tables -A INPUT -p ipv6-icmp --icmpv6-type echo-request -j ACCEPT
		ip6tables -A INPUT -p tcp --dport 22 -j ACCEPT
		ip6tables -A INPUT -i lo -j ACCEPT
		ip6tables -A INPUT -i "${LXC_BRIDGE}" -j ACCEPT

		# IPv6 FORWARD Zinciri (Chain)
		ip6tables -A FORWARD -m state --state RELATED,ESTABLISHED -j ACCEPT
		ip6tables -A FORWARD -i "${LXC_BRIDGE}" -o "${WAN_IF}" -j ACCEPT
		ip6tables -A FORWARD -d "${LXC_IPV6_NETWORK}" -j ACCEPT
		ip6tables -A OUTPUT -o "${WAN_IF}" -d "${LXC_IPV6_NETWORK}" -j DROP
	fi

	# IPv6 NAT Tablosu (Sadece LXC_IPV6_NAT true ise)
	if [ "${LXC_IPV6_NAT}" = "true" ]; then
		if [ -n "${WAN_IP6}" ]; then
			ip6tables -t nat -A POSTROUTING -s "${LXC_IPV6_NETWORK}" ! -o "${LXC_BRIDGE}" -j SNAT --to-source "${WAN_IP6}"
		else
			# Açık bir IPv6 adresi yoksa otomatik maskeleme yap
			ip6tables -t nat -A POSTROUTING -s "${LXC_IPV6_NETWORK}" ! -o "${LXC_BRIDGE}" -j MASQUERADE
		fi
	fi

fi


if [ -f "${NETWORK_RULES}" ] && [ -r "${NETWORK_RULES}" ]
then
	source "${NETWORK_RULES}" || true
fi
SET_LXC_NETWORK_RULES
chmod +x "${SET_LXC_NETWORK_RULES}"

if [ ! -f "${NETWORK_RULES}" ]
then
	rm -rf "${NETWORK_RULES}"
	cat > "${NETWORK_RULES}" << NETWORK_RULES
#####################
# Kullanım (USAGE)
#####################
# AddPortForward  <PROTOCOL> <WAN_PORT> <CONTAINER_IPv4> [<CONTAINER_PORT>]
# AddPortForward6 <PROTOCOL> <WAN_PORT> <CONTAINER_IPv6> [<CONTAINER_PORT>]

#####################
# Örnekler (Examples)
#####################
# IPv4
#AddPortForward tcp 80 10.0.3.20
#AddPortForward tcp 443 10.0.3.20
#AddPortForward udp 53 10.0.3.40
#AddPortForward tcp 10443 10.0.3.30 443

# IPv6
#AddPortForward6 tcp 80 fc42:5009:ba4b:5ab0::20
#AddPortForward6 tcp 443 fc42:5009:ba4b:5ab0::20
#AddPortForward6 udp 53 fc42:5009:ba4b:5ab0::40
#AddPortForward6 tcp 10443 fc42:5009:ba4b:5ab0::30 443
NETWORK_RULES
fi

mkdir -p "/etc/systemd/system/lxc-net.service.d/"
cat > "/etc/systemd/system/lxc-net.service.d/50-set-lxc-network-rules.conf" << SERVICE
[Unit]
After=nftables.service
[Service]
ExecStartPost=${SET_LXC_NETWORK_RULES}
SERVICE
systemctl daemon-reload

# Ağ yapılandırması sonrası hizmetlerin yeniden başlatılması
systemctl enable lxc-net.service
systemctl restart lxc-net.service

##########################################################################################
# Öntanımlı hâle getirilen kullanıcı tanımları
##########################################################################################
# Bu özellikle www-data gibi ortak bir ftp kullanıcısı olması için öntanımlı yapıldı.
useradd -mr -u 221 -g 33 -s /sbin/nologin -d /srv/ftp -c "ftp" ftp || true

##########################################################################################
# Kapsayıcının kurulum aşamaları
##########################################################################################
# Eğer mevcut bir kapsayıcı varsa kaldırılır.
if lxc-info -n "${PRODUCT_NAME,,}" > /dev/null 2>&1
then
	lxc-stop -n "${PRODUCT_NAME,,}" || true
	until lxc-info -s -n "${PRODUCT_NAME,,}" | grep -q STOPPED
	do
		echo "Kapsayıcının kapanması bekleniyor: ${PRODUCT_NAME,,}"
		sleep 1
	done
	lxc-destroy -n "${PRODUCT_NAME,,}"
fi

# Kapsayıcı(container) oluşturma
lxc-create "${PRODUCT_NAME,,}" -t debian -- -r trixie --flush-cache

# Kapsayıcı ağ yapılandırması
LXC_IFACE="$(grep "auto" "${LXC_DIR}/${PRODUCT_NAME,,}/rootfs/etc/network/interfaces" | awk '!/lo/ { print $2 }')"
cat > "${LXC_DIR}/${PRODUCT_NAME,,}/rootfs/etc/network/interfaces" << NETWORK_CONFIG
auto lo
iface lo inet loopback

auto ${LXC_IFACE}
iface ${LXC_IFACE} inet static
	address ${LXC_IP}/24
	gateway 10.0.3.1
	dns-nameservers $(awk '/^nameserver/ { print $2 }' "/etc/resolv.conf" | tr "\n" " ")
NETWORK_CONFIG

# Ana makine üzerindeki sertifikanın, kapsayıcıda da aynı dizinden erişlebilmesi için dizin bağlandı.
mkdir -p "/usr/local/share/certificates"
echo "lxc.mount.entry = /usr/local/share/certificates usr/local/share/certificates none bind,create=dir 0 0" >> "${LXC_DIR}/${PRODUCT_NAME,,}/config"

lxc-start -n "${PRODUCT_NAME,,}"
until lxc-info -s -n "${PRODUCT_NAME,,}" | grep -q RUNNING
do
	echo "Kapsayıcının açılması bekleniyor: ${PRODUCT_NAME,,}"
	sleep 1
done

# Kapsayıcı içerisindeki yapılacaklar
lxc-attach -n "${PRODUCT_NAME,,}" -- << \RUN_IN_CONTAINER
# Sistemin dili yapılandırıyor
cat > "/etc/default/locale" << DEFAULT_LOCALE
LANGUAGE=en_US.UTF-8
LC_ALL=en_US.UTF-8
LC_CTYPE=en_US.UTF-8
LANG=en_US.UTF-8
DEFAULT_LOCALE

cat > "/etc/locale.gen" << LOCALE
en_US.UTF-8 UTF-8
tr_TR.UTF-8 UTF-8
LOCALE
locale-gen
update-locale "LANG=en_US.UTF-8"

# Depoları yeniden oluşturuluyor
cat > "/etc/apt/sources.list" << \SOURCES_LIST
deb http://deb.debian.org/debian/ trixie main contrib non-free non-free-firmware
deb http://deb.debian.org/debian-security trixie-security main contrib non-free non-free-firmware
deb http://deb.debian.org/debian/ trixie-updates main contrib non-free non-free-firmware
SOURCES_LIST

# Temel sistem araçları ve gerekli paketlerin kurulumu
apt purge -y --auto-remove apt-listchanges
apt update
apt install -y \
	bash-completion openssh-server fzf autojump \
	file tree htop vim tmux wget curl coreutils locales \
	moreutils apt-transport-https gnupg gawk \
	debconf-utils bind9-dnsutils iputils-ping \
	unattended-upgrades needrestart netcat-openbsd

cat > "/etc/apt/apt.conf.d/20keepconfig.conf" <<\APT_KEEP_CONFIG
Dpkg::Options {
	"--force-confdef";
	"--force-confold";
}
APT_KEEP_CONFIG

##########################################################################################
# NeedRestart için otomatik yeniden başlatma
##########################################################################################
cat > "/etc/needrestart/conf.d/90-automatic-restart.conf" <<\NEEDRESTART_CONFIG
$nrconf{restart} = 'a';
NEEDRESTART_CONFIG

##########################################################################################
# Kullanıma dair düzenlemeler
##########################################################################################
cat > "/etc/vim/vimrc.local" << \VIM_CONFIG
source $VIMRUNTIME/defaults.vim
let skip_defaults_vim = 1
set noswapfile
set ignorecase
set smartcase
if has("mouse")
  set mouse=r
endif
VIM_CONFIG

chsh -s /bin/bash root

cat > "/root/.bashrc" << \BASHRC
# Color Bash Prompt
export PS1="\[\033[38;5;11m\]\u\[\033[38;5;9m\]@\h:\[\033[38;5;118m\][\$?]\[\033[38;5;51m\][\w]\[\033[38;5;6m\][\d - \t]\n\[\033[38;5;10m\][\\$\[\033[38;5;10m\]]\[\033[38;5;202m\]>\[\033[38;5;15m\]"

# Alias definitions.
# You may want to put all your additions into a separate file like
# ~/.bash_aliases, instead of adding them here directly.
# See /usr/share/doc/bash-doc/examples in the bash-doc package.

if [ -f ~/.bash_aliases ]; then
    . ~/.bash_aliases
fi

if [ -f ~/.bash_functions ]; then
    . ~/.bash_functions
fi

# If FZF is installed
if [ -f /usr/share/doc/fzf/examples/key-bindings.bash ]; then
    . /usr/share/doc/fzf/examples/key-bindings.bash
fi

# colored GCC warnings and errors
export GCC_COLORS='error=01;31:warning=01;35:note=01;36:caret=01;32:locus=01:quote=01'

# For Bash completion to work
if ! shopt -oq posix; then
  if [ -f /usr/share/bash-completion/bash_completion ]; then
    . /usr/share/bash-completion/bash_completion
  elif [ -f /etc/bash_completion ]; then
    . /etc/bash_completion
  fi
fi

# append to the history file, don't overwrite it
shopt -s histappend

# don't put duplicate lines or lines starting with space in the history.
# See bash(1) for more options
HISTCONTROL=ignoreboth

# for setting history length see HISTSIZE and HISTFILESIZE in bash(1)
export HISTSIZE=-1
export HISTFILESIZE=-1

export PROMPT_COMMAND="history -a;$PROMPT_COMMAND"
export LS_OPTIONS='--color=auto'
eval "`dircolors`"

# Aliases
alias ls='ls $LS_OPTIONS'
alias ll='ls $LS_OPTIONS -lh'
alias l='ls $LS_OPTIONS -lAh'
alias c='clear'
alias r='reset'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'
alias ......='cd ../../../../..'
BASHRC

# MOTD özellikleri
cat > "/etc/update-motd.d/30-tmux-list" << \MOTD_TMUX_LIST
#!/bin/bash
if command -v tmux > /dev/null 2>&1
then
	echo "#######################################################################"
	tmux ls 2>/dev/null || echo "There is no TMUX session open."
	echo "#######################################################################"
	echo
fi
MOTD_TMUX_LIST
chmod +x "/etc/update-motd.d/30-tmux-list"

chattr -i "/etc/motd"
rm "/etc/motd"
touch "/etc/motd"
chattr +i "/etc/motd"

##########################################################################################
# SSH yapılandırması
##########################################################################################
install -dm0700 ~/.ssh
wget "https://oktayaktogan.com.tr/ssh-keys.pub" -O ~/.ssh/authorized_keys
cat > "/etc/ssh/sshd_config.d/99-common.conf" << SSH_CONFIG
PermitRootLogin prohibit-password
PubkeyAuthentication yes
PasswordAuthentication no
PermitEmptyPasswords no
PrintMotd yes
PrintLastLog no
SSH_CONFIG
systemctl restart ssh.service

##########################################################################################
# JournalD yapılandırması
##########################################################################################
mkdir -p "/etc/systemd/journald.conf.d"
cat >> "/etc/systemd/journald.conf.d/99-delete-after-one-week.conf" <<JOURNALD
MaxRetentionSec=1week
MaxFileSec=1week
JOURNALD

##########################################################################################
# Ağ iyileştirmesi
##########################################################################################
cat > "/etc/sysctl.d/40-network-optimization.conf" << \NETWORK_OPTIMIZATION
# TCP ve UDP tampon bellek
net.core.rmem_max = 16777216
net.core.wmem_max = 16777216
net.ipv4.tcp_rmem= 10240 87380 16777216
net.ipv4.tcp_wmem= 10240 87380 16777216
net.ipv4.tcp_window_scaling = 1
net.ipv4.tcp_timestamps = 1
net.ipv4.tcp_sack = 1
net.ipv4.tcp_no_metrics_save = 1
NETWORK_OPTIMIZATION
sysctl -p "/etc/sysctl.d/40-network-optimization.conf"

##########################################################################################
# Öntanımlı hâle getirilen kullanıcı tanımları
##########################################################################################
# Bu özellikle www-data gibi ortak bir ftp kullanıcısı olması için öntanımlı yapıldı.
useradd -mr -u 221 -g 33 -s /sbin/nologin -d /srv/ftp -c "ftp" ftp || true

# Bash geçmisini temizleme
rm -f ~/.bash_history
RUN_IN_CONTAINER
